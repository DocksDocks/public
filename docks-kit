#!/bin/bash
# docks-kit — launcher. Resolution order:
#   1. version-matching compiled binary in cli/dist/ (bun build --compile output)
#   2. Bun from source (auto-installs Bun + node_modules when missing)
# No-Bun recovery path: download a release binary for your platform.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

# BEGIN GENERATED BUN PIN
BUN_PIN="1.3.14"
# END GENERATED BUN PIN

case "$(uname -s)-$(uname -m)" in
  Linux-x86_64)   KIT_BIN="docks-kit-linux-x64" ;;
  Linux-aarch64)  KIT_BIN="docks-kit-linux-arm64" ;;
  Darwin-x86_64)  KIT_BIN="docks-kit-darwin-x64" ;;
  Darwin-arm64)   KIT_BIN="docks-kit-darwin-arm64" ;;
  # Git Bash unames look like MINGW64_NT-10.0-19045-x86_64. The compiled
  # binary is the supported Windows path; the Bun fallback below is Unix-shaped.
  MINGW*-x86_64|MSYS*-x86_64|CYGWIN*-x86_64) KIT_BIN="docks-kit-windows-x64.exe" ;;
  *)              KIT_BIN="" ;;
esac
if [[ -n "$KIT_BIN" && -x "$REPO_DIR/cli/dist/$KIT_BIN" ]]; then
  CHECKOUT_VERSION=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*\"version\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
      CHECKOUT_VERSION="${BASH_REMATCH[1]}"
      break
    fi
  done < "$REPO_DIR/package.json"
  IFS= read -r BIN_VERSION < <("$REPO_DIR/cli/dist/$KIT_BIN" --version 2>/dev/null || true)
  BIN_VERSION="${BIN_VERSION%$'\r'}"
  if [[ -z "$CHECKOUT_VERSION" || "$BIN_VERSION" == "$CHECKOUT_VERSION" ]]; then
    exec "$REPO_DIR/cli/dist/$KIT_BIN" "$@"
  fi
  echo "[docks-kit] ignoring stale cli/dist/$KIT_BIN ${BIN_VERSION:-<unknown>}; checkout is $CHECKOUT_VERSION — running from source" >&2
fi

# Locate bun: PATH, then the known install locations that sit off the
# non-interactive PATH (~/.bun/bin, ~/.local/bin).
find_bun() {
  local c
  c="$(command -v bun 2>/dev/null || true)"
  [[ -n "$c" ]] && { printf '%s\n' "$c"; return 0; }
  for c in "${BUN_INSTALL:-$HOME/.bun}/bin/bun" "$HOME/.bun/bin/bun" "$HOME/.local/bin/bun"; do
    [[ -x "$c" ]] && { printf '%s\n' "$c"; return 0; }
  done
  return 1
}

if ! BUN="$(find_bun)"; then
  echo "[docks-kit] Bun not found — installing (download-then-run)..." >&2
  if ! command -v curl >/dev/null 2>&1; then
    echo "[docks-kit] curl missing too. Install Bun manually (https://bun.sh) or download a docks-kit release binary." >&2
    exit 1
  fi
  # The installer takes a bun-vX.Y.Z release tag as $1. BUN_PIN is generated
  # from the authoring toolchain manifest alongside the embedded payload.
  tmp_installer=$(mktemp 2>/dev/null || echo "/tmp/bun-install-$$.sh")
  curl -fsSL https://bun.sh/install -o "$tmp_installer" && bash "$tmp_installer" ${BUN_PIN:+"bun-v$BUN_PIN"} >/dev/null 2>&1 || true
  rm -f "$tmp_installer"
  if ! BUN="$(find_bun)"; then
    echo "[docks-kit] Bun install failed. Download a docks-kit release binary for a no-Bun recovery path." >&2
    exit 1
  fi
fi

# Sentinel is a real dependency dir, not bare node_modules/ — a failed or
# partial install leaves node_modules/ present and would suppress the repair.
if [[ ! -d "$REPO_DIR/node_modules/@effect/cli" ]]; then
  echo "[docks-kit] Installing CLI dependencies (bun install --frozen-lockfile)..." >&2
  (cd "$REPO_DIR" && "$BUN" install --frozen-lockfile >/dev/null)
fi

exec "$BUN" "$REPO_DIR/cli/src/main.ts" "$@"
