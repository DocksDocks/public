#!/usr/bin/env bash
# Managed by DocksDocks/public sync.sh.
# Stable Codex launcher for shells that do not source nvm before PATH lookup.
set -euo pipefail

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [[ -d "$NVM_DIR/versions/node" ]]; then
  codex_bin="$(
    find "$NVM_DIR/versions/node" -path '*/bin/codex' \( -type f -o -type l \) 2>/dev/null \
      | sort -V \
      | tail -n 1
  )"

  if [[ -n "$codex_bin" && -x "$codex_bin" ]]; then
    export PATH="$(dirname "$codex_bin"):$PATH"
    exec "$codex_bin" "$@"
  fi
fi

for candidate in /usr/local/bin/codex /usr/bin/codex /opt/homebrew/bin/codex; do
  if [[ -x "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

echo "codex launcher could not find a Codex CLI binary. Install with npm install -g @openai/codex." >&2
exit 127
